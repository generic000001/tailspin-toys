---
import Layout from '../layouts/Layout.astro';
import GameCard from '../components/GameCard.astro';
import PageHero from '../components/PageHero.astro';
import EmptyState from '../components/EmptyState.astro';
import { getDatabase } from '../lib/db';
import { getAllGames, getGameFilterOptions } from '../lib/games';

export const prerender = true;

const db = getDatabase();
const [games, filterOptions] = await Promise.all([getAllGames(db), getGameFilterOptions(db)]);
---

<Layout title="Tailspin Toys - Crowdfunding your new favorite game!">
  <div class="py-8">
    <PageHero
      title="Welcome to Tailspin Toys"
      subtitle="Find your next game! And maybe even back one! Explore our collection!"
    />

    <div>
      <h2 class="text-2xl font-medium mb-6 text-slate-100">Featured Games</h2>

      <section
        class="mb-6 p-4 rounded-xl border border-slate-700 bg-slate-800/60 backdrop-blur-sm"
        aria-labelledby="game-filters-heading"
        data-testid="game-filters"
      >
        <h3 id="game-filters-heading" class="text-lg font-medium text-slate-100 mb-4">Filter games</h3>
        <form class="space-y-4" aria-describedby="filter-results-status">
          <fieldset>
            <legend class="text-sm font-medium text-slate-200 mb-2">Categories</legend>
            <div class="flex flex-wrap gap-3" data-testid="category-filter-group">
              {filterOptions.categories.map((category) => (
                <label
                  class="inline-flex items-center gap-2 rounded-lg border border-slate-600 px-3 py-2 text-sm text-slate-200 hover:bg-slate-700/60"
                  for={`category-filter-${category.id}`}
                >
                  <input
                    id={`category-filter-${category.id}`}
                    name="category-filter"
                    type="checkbox"
                    value={category.id}
                    class="h-4 w-4 rounded border-slate-500 bg-slate-900 text-blue-500 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                    data-testid={`category-filter-${category.id}`}
                  />
                  <span>{category.name}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <div class="max-w-xs">
            <label class="block text-sm font-medium text-slate-200 mb-2" for="publisher-filter">Publisher</label>
            <select
              id="publisher-filter"
              name="publisher-filter"
              class="w-full rounded-lg border border-slate-600 bg-slate-900 px-3 py-2 text-slate-100 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              data-testid="publisher-filter"
            >
              <option value="">All publishers</option>
              {filterOptions.publishers.map((publisher) => (
                <option value={publisher.id}>{publisher.name}</option>
              ))}
            </select>
          </div>

          <div class="flex items-center gap-3">
            <button
              id="clear-filters-button"
              type="button"
              class="rounded-lg border border-slate-600 px-3 py-2 text-sm font-medium text-slate-200 hover:bg-slate-700 transition-colors duration-200 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              data-testid="clear-filters-button"
            >
              Clear filters
            </button>
            <p
              id="filter-results-status"
              class="text-sm text-slate-300"
              role="status"
              aria-live="polite"
              data-testid="filter-results-status"
            >
              Showing {games.length} of {games.length} games
            </p>
          </div>
        </form>
      </section>

      {games.length === 0 ? (
        <EmptyState text="No games available at the moment." />
      ) : (
        <>
          <div class="hidden mb-4" id="filtered-empty-state" data-testid="filtered-empty-state">
            <EmptyState text="No games match the selected filters." />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" data-testid="games-grid">
            {games.map((game) => <GameCard game={game} />)}
          </div>
        </>
      )}
    </div>
  </div>
</Layout>

<script>
  const grid = document.querySelector('[data-testid="games-grid"]');
  const status = document.querySelector('[data-testid="filter-results-status"]');
  const publisherSelect = document.querySelector('[data-testid="publisher-filter"]');
  const categoryInputs = Array.from(document.querySelectorAll('input[name="category-filter"]'));
  const clearFiltersButton = document.getElementById('clear-filters-button');
  const filteredEmptyState = document.getElementById('filtered-empty-state');

  if (
    grid instanceof HTMLElement &&
    publisherSelect instanceof HTMLSelectElement &&
    clearFiltersButton instanceof HTMLButtonElement &&
    status instanceof HTMLElement
  ) {
    const cards = Array.from(grid.querySelectorAll('[data-testid="game-card"]'));

    const applyFilters = () => {
      const selectedCategoryIds = [];
      for (const input of categoryInputs) {
        if (input instanceof HTMLInputElement && input.checked) {
          selectedCategoryIds.push(input.value);
        }
      }
      const selectedCategorySet = new Set(selectedCategoryIds);
      const selectedPublisherId = publisherSelect.value;

      let visibleCount = 0;
      for (const card of cards) {
        const categoryId = card.getAttribute('data-category-id') ?? '';
        const publisherId = card.getAttribute('data-publisher-id') ?? '';
        const matchesCategory = selectedCategorySet.size === 0 || selectedCategorySet.has(categoryId);
        const matchesPublisher = selectedPublisherId.length === 0 || selectedPublisherId === publisherId;
        const isVisible = matchesCategory && matchesPublisher;

        card.classList.toggle('hidden', !isVisible);
        if (isVisible) {
          visibleCount += 1;
        }
      }

      if (filteredEmptyState instanceof HTMLElement) {
        filteredEmptyState.classList.toggle('hidden', visibleCount > 0);
      }

      status.textContent = `Showing ${visibleCount} of ${cards.length} games`;

      const searchParams = new URLSearchParams(window.location.search);
      searchParams.delete('category');
      for (const categoryId of selectedCategoryIds) {
        searchParams.append('category', categoryId);
      }

      if (selectedPublisherId) {
        searchParams.set('publisher', selectedPublisherId);
      } else {
        searchParams.delete('publisher');
      }

      const query = searchParams.toString();
      const nextUrl = query ? `${window.location.pathname}?${query}` : window.location.pathname;
      window.history.replaceState({}, '', nextUrl);
    };

    const loadFiltersFromUrl = () => {
      const searchParams = new URLSearchParams(window.location.search);
      const selectedCategoryIds = new Set(searchParams.getAll('category'));
      const selectedPublisherId = searchParams.get('publisher') ?? '';

      for (const input of categoryInputs) {
        if (input instanceof HTMLInputElement) {
          input.checked = selectedCategoryIds.has(input.value);
        }
      }

      const publisherOptionExists = Array.from(publisherSelect.options).some(
        (option) => option.value === selectedPublisherId,
      );
      if (publisherOptionExists) {
        publisherSelect.value = selectedPublisherId;
      }
    };

    for (const categoryInput of categoryInputs) {
      categoryInput.addEventListener('change', applyFilters);
    }

    publisherSelect.addEventListener('change', applyFilters);
    clearFiltersButton.addEventListener('click', () => {
      for (const input of categoryInputs) {
        if (input instanceof HTMLInputElement) {
          input.checked = false;
        }
      }
      publisherSelect.value = '';
      applyFilters();
    });

    loadFiltersFromUrl();
    applyFilters();
  }
</script>
